# Dependencies
/node_modules
/.pnp
.pnp.js

# Testing
/coverage

# Production
/build

# Next.js build output (NEVER commit — Next inlines NEXT_PUBLIC_* env vars
# into compiled JS at build time, so committing this leaks secrets).
.next/
/out

# Misc
.DS_Store
.env
.env.*
!.env.example

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db

/data/daily

# Script logs + backtest scratch outputs (generated locally, not runtime).
# Keep top-reads.json and track-record-reads.json — the site reads those.
*.log
track-record-candidates*
track-record-passed*

# Local backtest cache (regenerate with scripts/collect-backtest-data.mjs)
backtest-data.json
